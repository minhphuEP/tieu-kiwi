# Copy this file to .env and fill in real values:  cp .env.example .env
# .env is git-ignored — never commit real secrets.

# ── Core (required to run the agent today) ───────────────────────────────
# Anthropic Claude API key — powers the agent's reasoning / tool-use loop
# AND the ingestion pipelines' LLM extract (when LLM_PROVIDER=anthropic).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Postgres connection string for the knowledge graph.
# Matches the credentials in docker-compose.yml for local dev.
DATABASE_URL=postgresql://tieukiwi_app:devpass@localhost:5432/tieukiwi

# Ollama fallback (only used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b

# ── Model configuration ──────────────────────────────────────────────────
# Default model for the agent (falls back to claude-sonnet-4-6 if unset).
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional per-task overrides, leave empty to use the default:
MODEL_AGENT=
MODEL_GEN_CRITIC=
MODEL_GEN_TESTCASE=
MODEL_GEN_TEST_PLAN=

# ── Jira (reserved) — consumed by the fetch_jira tool (currently a skeleton) ──
# Base URL of your Jira Cloud instance, e.g. https://your-org.atlassian.net
JIRA_BASE_URL=
# Jira account email — used as the Basic-auth username.
JIRA_EMAIL=
# Jira API token — create at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# ── Slack (Layer B, Socket Mode) — run: python -m tieukiwi.slack_app ──────
# Bot User OAuth token (starts with xoxb-)
SLACK_BOT_TOKEN=
# App-level token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=
# Signing secret (from the app's Basic Information page)
SLACK_SIGNING_SECRET=
# Slack user id of the Delivery Manager who signs off go-live releases (e.g. U0123ABC).
# Unset -> the go-live approval block shows a plain "@Delivery Manager" label instead of a real mention.
DELIVERY_MANAGER_SLACK_ID=
